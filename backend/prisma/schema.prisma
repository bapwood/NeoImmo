// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  ADMIN
}

enum WalletStatus {
  UNSET
  PENDING
  VERIFIED
}

enum TokenizationStatus {
  DRAFT
  DEPLOYED
  ACTIVE
  PAUSED
  ARCHIVED
}

enum BlockchainOperationType {
  SYNC_WALLET_KYC
  SET_BLOCKLIST
  SET_BLOCKED_COUNTRY
  DEPLOY_PROPERTY
  MINT_PROPERTY
  PREPARE_PRIMARY_BUY
  EXECUTE_PRIMARY_BUY
}

enum BlockchainOperationStatus {
  PREPARED
  SUBMITTED
  CONFIRMED
  FAILED
  CANCELLED
}

enum PortfolioRevenueStatus {
  PROJECTED
  PAID
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  role         Role          @default(CLIENT)
  createdAt    DateTime      @default(now())
  firstName    String?
  lastName     String?
  address      String?
  postalCode   String?
  city         String?
  country      String?
  day          String?
  month        String?
  year         String?
  birthPlace   String?
  nationality  String?
  number       String?
  occupation   String?
  taxResidence String?
  annualIncomeRange String?
  investmentObjective String?
  countryCode  String?
  walletAddress String?      @unique
  walletStatus WalletStatus  @default(UNSET)
  walletVerifiedAt DateTime?
  kycSyncedAt  DateTime?
  isRestricted Boolean      @default(false)
  restrictedAt DateTime?
  refreshToken RefreshToken?
  properties   Property[]
  blockchainOperations BlockchainOperation[]
  portfolioPositions PortfolioPosition[]
  portfolioRevenues PortfolioRevenue[]
}

model RefreshToken {
  token      String   @unique
  userId     Int      @id
  expiryDate DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id             Int      @id @default(autoincrement())
  name           String
  createdAt      DateTime @default(now())
  ownerId        Int?
  localization   String
  livingArea     String
  score          Int
  description    String
  roomNumber     Int
  bathroomNumber Int
  tokenNumber    Int
  tokenPrice     Int
  symbol         String?
  contractAddress String?   @unique
  chainId        Int?
  metadataUri    String?
  metadataHash   String?
  metadataSignature String?
  deployTxHash   String?
  tokenizationStatus TokenizationStatus @default(DRAFT)
  treasuryWalletAddress String?
  backendOperatorWalletAddress String?
  tokenDecimals  Int      @default(18)
  images         String[]
  keyPoints      KeyPoint[]
  owner          User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  blockchainOperations BlockchainOperation[]
  portfolioPositions PortfolioPosition[]
  portfolioRevenues PortfolioRevenue[]
}

model KeyPoint {
  id         Int        @id @default(autoincrement())
  label      String     @unique
  createdAt  DateTime   @default(now())
  properties Property[]
}

model BlockchainOperation {
  id         Int      @id @default(autoincrement())
  requestId  String?  @unique
  type       BlockchainOperationType
  status     BlockchainOperationStatus @default(PREPARED)
  chainId    Int?
  propertyId Int?
  userId     Int?
  fromWallet String?
  toWallet   String?
  amount     String?
  price      String?
  currency   String?
  nonce      String?
  deadline   DateTime?
  signature  String?
  txHash     String?
  payload    Json?
  errorMessage String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PortfolioPosition {
  id                     Int       @id @default(autoincrement())
  userId                 Int
  propertyId             Int
  tokenAmount            String
  averageTokenPrice      Int
  investedTotal          Int
  projectedMonthlyIncome Int       @default(0)
  lastPurchaseAt         DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property               Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  revenueRecords         PortfolioRevenue[]

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model PortfolioRevenue {
  id         Int                   @id @default(autoincrement())
  positionId Int
  userId     Int
  propertyId Int
  month      DateTime
  amount     Int
  status     PortfolioRevenueStatus @default(PROJECTED)
  label      String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  position   PortfolioPosition     @relation(fields: [positionId], references: [id], onDelete: Cascade)
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([positionId, month])
  @@index([userId, month])
  @@index([propertyId, month])
}
